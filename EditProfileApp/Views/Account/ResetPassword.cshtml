@model EditProfileApp.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "ตั้งรหัสผ่านใหม่";
}

<style>
    body {
        background-color: #1a2e4c !important;
    }

    .reset-card {
        border-radius: 15px;
        border: none;
    }

    .btn-theme {
        background-color: #e87722;
        color: white;
        border: none;
        font-weight: bold;
    }

        .btn-theme:hover {
            background-color: #d1661a;
            color: white;
        }

    .otp-input {
        letter-spacing: 0.5rem;
        font-size: 1.5rem;
        text-align: center;
        font-weight: bold;
    }
</style>

<div class="row justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="col-md-5">
        <div class="card reset-card shadow">
            <div class="card-body p-5">
                <h3 class="text-center fw-bold mb-3" style="color: #1a2e4c;">ยืนยันตัวตน</h3>
                <p class="text-center text-muted mb-4">กรุณากรอกรหัส OTP ที่ได้รับในอีเมลและตั้งรหัสผ่านใหม่</p>

                <form asp-action="ResetPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">รหัส OTP (6 หลัก)</label>
                        <input asp-for="Otp" class="form-control form-control-lg bg-light otp-input"
                               placeholder="000000" maxlength="6" required autofocus />
                        <span asp-validation-for="Otp" class="text-danger small"></span>
                    </div>

                    <hr class="my-4">

                    <div class="mb-3">
                        <label class="form-label fw-bold">รหัสผ่านใหม่</label>
                        <input asp-for="NewPassword" type="password" class="form-control"
                               placeholder="อย่างน้อย 6 ตัวอักษร" required />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">ยืนยันรหัสผ่านใหม่</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control"
                               placeholder="กรอกรหัสผ่านอีกครั้ง" required />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-theme btn-lg">เปลี่ยนรหัสผ่าน</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}