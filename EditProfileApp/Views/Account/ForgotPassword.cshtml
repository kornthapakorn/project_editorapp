@model EditProfileApp.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "ลืมรหัสผ่าน";
}

<style>
    body {
        background-color: #1a2e4c !important;
    }

    .forgot-card {
        border-radius: 15px;
        border: none;
    }

    .btn-theme {
        background-color: #e87722;
        color: white;
        border: none;
        font-weight: bold;
    }

        .btn-theme:hover {
            background-color: #d1661a;
            color: white;
        }
</style>

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5">
        <div class="card forgot-card shadow">
            <div class="card-body p-5">
                <h3 class="text-center fw-bold mb-4" style="color: #1a2e4c;">ลืมรหัสผ่าน?</h3>
                <p class="text-center text-muted mb-4">ระบบจะส่งรหัส OTP ไปที่อีเมลสถาบันของคุณ (@@kmitl.ac.th)</p>

                <form asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">รหัสนักศึกษา</label>
                        <input asp-for="StudentId" class="form-control form-control-lg bg-light" placeholder="" required autofocus />
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-theme btn-lg">ส่งรหัส OTP</button>
                        <a asp-action="Login" class="btn btn-link text-decoration-none">กลับไปหน้าล็อกอิน</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>