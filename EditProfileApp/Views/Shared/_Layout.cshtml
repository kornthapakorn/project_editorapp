<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CE KMITL PCC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EditProfileApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <header>
        @if (User.Identity.IsAuthenticated)
        {
            <nav class="navbar navbar-expand-sm navbar-dark border-bottom box-shadow mb-3" style="background-color: #1a2e4c;">
                <div class="container-fluid">

                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="~/images/kmitl_logo.png" alt="CE Logo" height="45" style="background-color: white; padding: 2px; border-radius: 5px;">
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMobileMenu" aria-controls="navbarMobileMenu" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between" id="navbarMobileMenu">
                        <ul class="navbar-nav flex-grow-1"></ul>

                        <ul class="navbar-nav mt-3 mt-sm-0 gap-2">
                            <li class="nav-item d-flex align-items-center">
                                <span class="nav-link text-white bg-white bg-opacity-10 rounded-pill px-3 py-1 small w-100 text-center">
                                    <i class="bi bi-person-vcard me-1"></i>
                                    ID: <span class="fw-bold text-warning">@User.Identity.Name</span>
                                </span>
                            </li>

                            <li class="nav-item d-flex align-items-center">
                                <button type="button" class="btn btn-warning btn-sm px-3 fw-bold shadow-sm w-100"
                                        data-bs-toggle="modal" data-bs-target="#changePasswordModal"
                                        style="letter-spacing: 0.5px;">
                                    <i class="bi bi-key-fill me-1"></i> เปลี่ยนรหัสผ่าน
                                </button>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-danger btn-sm px-3 fw-bold shadow-sm text-white w-100"
                                   href="javascript:void(0);"
                                   id="btnLogout"
                                   style="text-shadow: 0px 1px 2px rgba(0,0,0,0.2); letter-spacing: 0.5px;">
                                    <i class="bi bi-box-arrow-right me-1"></i> ออกจากระบบ
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>

            <div class="modal fade" id="changePasswordModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header bg-warning text-dark border-bottom-0">
                            <h5 class="modal-title fw-bold"><i class="bi bi-shield-lock-fill"></i> เปลี่ยนรหัสผ่าน (OTP)</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body p-4">
                            <div id="step1">
                                <p class="text-muted small text-center mb-4">ระบบจะส่งรหัส OTP 6 หลักไปยังอีเมลสถาบันเพื่อยืนยันตัวตนครับ</p>
                                <button id="btnRequestOtp" class="btn btn-primary w-100 fw-bold shadow-sm py-2">
                                    <i class="bi bi-envelope-paper me-1"></i> รับรหัส OTP ผ่านอีเมล
                                </button>
                            </div>

                            <div id="step2" style="display: none;">
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-muted">รหัส OTP 6 หลัก</label>
                                    <input type="text" id="inputOtp" class="form-control text-center form-control-lg" placeholder="X X X X X X" maxlength="6" style="letter-spacing: 5px; font-weight: bold;">
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">รหัสผ่านใหม่</label>
                                    <input type="password" id="inputNewPassword" class="form-control" placeholder="ตั้งรหัสผ่านใหม่ของคุณ">
                                </div>
                                <button id="btnSubmitChangePass" class="btn btn-success w-100 fw-bold shadow-sm py-2">
                                    <i class="bi bi-check-circle me-1"></i> ยืนยันการเปลี่ยนรหัสผ่าน
                                </button>
                            </div>

                            <div id="alertMessage" class="mt-3 text-center fw-bold small"></div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            Created by Thapakorn Phothikhaw and Nantawut Nantang
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const logoutBtn = document.getElementById('btnLogout');
            if (logoutBtn) {
                logoutBtn.addEventListener('click', function (e) {
                    e.preventDefault();

                    Swal.fire({
                        title: 'ยืนยันการออกจากระบบ?',
                        text: "คุณต้องการสิ้นสุดการใช้งานในขณะนี้ใช่หรือไม่",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#e87722',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: 'ใช่, ออกจากระบบ',
                        cancelButtonText: 'ยกเลิก',
                        background: '#ffffff',
                        color: '#1a2e4c',
                        borderRadius: '15px'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = '@Url.Action("Logout", "Account")';
                        }
                    });
                });
            }

            $('#btnRequestOtp').click(function () {
                var btn = $(this);
                var originalText = btn.html();

                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>กำลังส่ง...');
                $('#alertMessage').text('');

                $.post('/Account/SendPasswordChangeOtp', function (response) {
                    if (response.success) {
                        $('#alertMessage').removeClass('text-danger').addClass('text-success').text(response.message);
                        $('#step1').hide();
                        $('#step2').fadeIn();
                    } else {
                        $('#alertMessage').removeClass('text-success').addClass('text-danger').text(response.message);
                        btn.prop('disabled', false).html(originalText);
                    }
                }).fail(function() {
                    $('#alertMessage').removeClass('text-success').addClass('text-danger').text("เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์");
                    btn.prop('disabled', false).html(originalText);
                });
            });

            $('#btnSubmitChangePass').click(function () {
                var otpVal = $('#inputOtp').val();
                var newPassVal = $('#inputNewPassword').val();

                if(!otpVal || !newPassVal) {
                    $('#alertMessage').removeClass('text-success').addClass('text-danger').text("กรุณากรอก OTP และรหัสผ่านใหม่ให้ครบถ้วน");
                    return;
                }

                var btn = $(this);
                var originalText = btn.html();

                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>กำลังตรวจสอบ...');
                $('#alertMessage').text('');

                $.post('/Account/VerifyOtpAndChangePassword', { otp: otpVal, newPassword: newPassVal }, function (response) {
                    if (response.success) {
                        $('#changePasswordModal').modal('hide');
                        Swal.fire({
                            title: 'สำเร็จ!',
                            text: response.message,
                            icon: 'success',
                            confirmButtonColor: '#198754'
                        });

                        resetPasswordModal();
                    } else {
                        $('#alertMessage').removeClass('text-success').addClass('text-danger').text(response.message);
                        btn.prop('disabled', false).html(originalText);
                    }
                }).fail(function() {
                    $('#alertMessage').removeClass('text-success').addClass('text-danger').text("เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์");
                    btn.prop('disabled', false).html(originalText);
                });
            });

            $('#changePasswordModal').on('hidden.bs.modal', function () {
                resetPasswordModal();
            });

            function resetPasswordModal() {
                $('#step2').hide();
                $('#step1').show();
                $('#inputOtp').val('');
                $('#inputNewPassword').val('');
                $('#alertMessage').text('');
                $('#btnRequestOtp').prop('disabled', false).html('<i class="bi bi-envelope-paper me-1"></i> รับรหัส OTP ผ่านอีเมล');
            }
        });
    </script>
</body>
</html>